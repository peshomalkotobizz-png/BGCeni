# ================================================================
# ЦениBG — Конфигурация (.env)
# Преименувай този файл на .env и попълни стойностите
# ================================================================

# Тайни ключ за сесиите (сложи произволен дълъг текст)
SECRET_KEY=cenibg-super-secret-key-change-me-in-production

# База данни (SQLite по подразбиране, не е нужно нищо)
# За PostgreSQL: postgresql://user:password@localhost/cenibg
DATABASE_URL=sqlite:///cenibg.db

# ── STRIPE (от https://dashboard.stripe.com) ──────────────────
# Тестови ключове (pk_test_... / sk_test_...) са безопасни за тест
STRIPE_SECRET_KEY=sk_test_ЗАМЕНИ_С_ТВОЯ_КЛЮЧ
STRIPE_PUBLISHABLE_KEY=pk_test_ЗАМЕНИ_С_ТВОЯ_КЛЮЧ

# ID на ценовия план (създай го в Stripe Dashboard → Products)
# Цена: 4.00 BGN, Recurring Monthly
STRIPE_PRICE_ID=price_ЗАМЕНИ_С_ID_НА_ПЛАНА

# Webhook secret (от Stripe CLI: stripe listen --print-secret)
STRIPE_WEBHOOK_SECRET=whsec_ЗАМЕНИ

# ── ИМЕЙЛ (Gmail пример) ──────────────────────────────────────
# 1. Включи "2-Step Verification" в Google акаунта
# 2. Генерирай "App Password" от myaccount.google.com/apppasswords
# 3. Постави го тук (без интервали)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=твоят@gmail.com
MAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx
